package "Layers.Base" #E8F5E9 {
    
    interface IProtocolLayer {
        + LayerName : string <<readonly>>
        + LayerLevel : int <<readonly>>
        + IsInitialized : bool <<readonly>>
        + UpperLayer : IProtocolLayer?
        + LowerLayer : IProtocolLayer?
        --
        + InitializeAsync(config: LayerConfiguration?) : Task<bool>
        + Shutdown() : void

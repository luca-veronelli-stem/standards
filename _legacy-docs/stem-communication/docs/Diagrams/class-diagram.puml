    package "Base.Enums" {
        enum LayerStatus {
            Success
            Error
            Incomplete
            Skipped
        }
        
        enum FlowDirection {
            Upstream
            Downstream
        }
    }
    
    package "Base.Models" {
        class LayerConfiguration {
            + EnableDetailedLogging : bool
            + TimeoutMs : int
            + MaxRetries : int

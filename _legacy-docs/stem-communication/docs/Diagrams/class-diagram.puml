            + IsSuccess : bool <<readonly>>
            + IsError : bool <<readonly>>
            + NeedsMoreData : bool <<readonly>>
            --
            + {static} Success(data: byte[], metadata?) : LayerResult
            + {static} Error(message: string, exception?) : LayerResult
            + {static} Incomplete() : LayerResult
            + {static} Skipped(data: byte[]) : LayerResult
        }
        
        class LayerContext {
            + TransactionId : Guid
            + Timestamp : DateTime
            + SenderId : uint
            + DestinationId : uint
            + CryptType : CryptType
            + ChannelType : ChannelType
            + Direction : FlowDirection
            + OriginalPayloadLength : int?
            + PacketId : byte?
            + NextHop : uint?
            + HopCount : int
            + Priority : PacketPriority
            + ExtendedMetadata : Dictionary<string, object>
            --
            + SetMetadata(key: string, value: object) : void
            + GetMetadata<T>(key: string) : T?
        }
    }
}

